{
  "name": "RNERadialGauge",
  "version": "1.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wavemaker/wm-react-native-echarts"
  },
  "homepage": "https://wavemaker.github.io/wm-react-native-echarts/?path=/story/charts-gauge-radial--default",
  "displayName": "Radial Gauge",
  "description": "Radial gauge chart with circular progress ring and animated pointer displaying values",
  "iconUrl": "icon.svg",
  "component": "radial-gauge.chart.tsx",
  "requires": [
    "../../chart-container.tsx",
    "../../chart-theme.context.tsx"
  ],
  "dependencies": {
    "@wavemaker/react-native-echarts": "1.0.1",
    "@shopify/react-native-skia": "2.6.2"
  },
  "keywords": [
    "gauge",
    "chart",
    "radial",
    "circular",
    "progress",
    "ring",
    "visualization",
    "metric",
    "indicator",
    "chart/gauge"
  ],
  "props": {
    "value": {
      "name": "value",
      "displayName": "Value",
      "description": "Current value to display. Example: 75",
      "type": "number",
      "isList": false,
      "isRequired": true
    },
    "min": {
      "name": "min",
      "displayName": "Min",
      "description": "Minimum value of the gauge scale. Example: 0",
      "type": "number",
      "isList": false,
      "defaultValue": 0,
      "isRequired": false
    },
    "max": {
      "name": "max",
      "displayName": "Max",
      "description": "Maximum value of the gauge scale. Example: 100",
      "type": "number",
      "isList": false,
      "defaultValue": 100,
      "isRequired": false
    },
    "width": {
      "name": "width",
      "displayName": "Width",
      "description": "Width of the chart in pixels.",
      "type": "string",
      "pattern": "^\\d+(%|px|pt)?$",
      "defaultValue": "100%",
      "isList": false,
      "isRequired": false
    },
    "height": {
      "name": "height",
      "displayName": "Height",
      "description": "Height of the chart in pixels.",
      "type": "string",
      "pattern": "^\\d+(%|px|pt)?$",
      "defaultValue": "300",
      "isList": false,
      "isRequired": false
    },
    "theme": {
      "name": "theme",
      "displayName": "Theme",
      "description": "Partial theme override for customizing chart appearance. Example: {series: [{color: '#3b82f6'}]}",
      "type": "object",
      "isList": false,
      "isRequired": false,
      "show": false
    },
    "colors": {
      "name": "colors",
      "displayName": "Colors",
      "description": "Colors for the chart. Example: ['#3b82f6', '#10b981', '#f59e0b']",
      "type": "string",
      "isList": true,
      "isRequired": false
    }
  },
  "group": "chart/gauge",
  "marketplace": {
    "carouselImages": [
      "/assets/images/radial.png"
    ],
    "thumbnailImage": "/assets/images/thumbnail.png",
    "icon": "icon.svg",
    "previewUrl": "https://wavemaker.github.io/wm-react-native-echarts/?path=/story/charts-gauge-radial--default"
  },
  "webSupport": true
}
